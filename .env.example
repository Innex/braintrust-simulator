# OpenAI API Key (required for API mode simulator LLM)
OPENAI_API_KEY=sk-your-openai-key-here

# Braintrust API URL (optional, defaults to https://api.braintrust.dev/v1)
# BRAINTRUST_API_URL=https://api.braintrust.dev/v1

# Braintrust App URL (optional, defaults to https://www.braintrust.dev)
# BRAINTRUST_APP_URL=https://www.braintrust.dev

# Note: Braintrust API key is provided by the user in the UI
# and is NOT stored as an environment variable
